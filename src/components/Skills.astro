<style>
  .container {
    margin: 0 auto;
    max-width: 120rem;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    align-items: center;
    height: 100vh;
  }
  .content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 2rem;
  }

  .content h3 {
    font-size: 5rem;
    font-weight: 700;
    color: #333;
    padding: 2rem 0;
  }

  .content p {
    font-size: 1.8rem;
    color: #7d7d7d;
  }

  .hero {
    display: flex;
    justify-content: center;
  }

  .hero img {
    width: 50rem;
    height: auto;

    -webkit-mask-image: radial-gradient(
      circle,
      rgba(0, 0, 0, 1) 30%,
      rgba(0, 0, 0, 0) 100%
    );
    mask-image: radial-gradient(
      circle,
      rgba(0, 0, 0, 1) 30%,
      rgba(0, 0, 0, 0) 100%
    );
  }
  .icon-container {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 30px;
  }
  .icon {
    text-align: center;
    color: #7d7d7d;
  }
  .icon svg {
    width: 50px;
    height: 50px;
    fill: #7d7d7d;
  }

  .icon p {
    margin-top: 5px;
    font-size: 14px;
  }

  .icon:hover {
    cursor: pointer;
  }
  .icon:hover .html {
    fill: #e44d26;
  }
  .icon:hover .css {
    fill: #264de4;
  }
  .icon:hover .sass {
    fill: #c69;
  }
  .icon:hover .tailwindcss {
    fill: #38bdf8;
  }

  .icon:hover .javascript {
    fill: #f0db4f;
  }

  .icon:hover .reactjs {
    fill: #61dbfb;
  }

  .icon:hover .npm {
    fill: #cb3837;
  }

  .icon:hover .sql {
    fill: #4479a1;
  }

  .icon:hover .php {
    fill: #8892be;
  }

  .icon:hover .laravel {
    fill: #ff2d20;
  }

  .icon:hover .wordpress {
    fill: #21759b;
  }

  .icon:hover .astro {
    fill: #17191e;
  }

  .icon:hover .directus {
    fill: #0e1c2f;
  }
</style>
