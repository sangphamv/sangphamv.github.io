---

<div class="proficiency">
  <div class="container">
    <div class="content">
      <h3>Proficiency</h3>
      <div class="skill design">
        <div class="skill-name">Design</div>
        <div class="progress-bar">
          <div class="progress"></div>
        </div>
      </div>
      <div class="skill digital-marketing">
        <div class="skill-name">Digital Marketing</div>
        <div class="progress-bar">
          <div class="progress"></div>
        </div>
      </div>
      <div class="skill frontend">
        <div class="skill-name">Frontend</div>
        <div class="progress-bar">
          <div class="progress"></div>
        </div>
      </div>
      <div class="skill backend">
        <div class="skill-name">Backend</div>
        <div class="progress-bar">
          <div class="progress"></div>
        </div>
      </div>
      <div class="skill programming">
        <div class="skill-name">Programming</div>
        <div class="progress-bar">
          <div class="progress"></div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .container {
    margin: 0 auto;
    max-width: 120rem;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    align-items: center;
    height: 100vh;
  }

  .content {
    width: 100%;
    margin: 0 auto;
  }
  h3 {
    font-size: 5rem;
    font-weight: 700;
    color: #333;
    padding: 2rem 0;
  }
  .skill {
    margin: 20px 0;
  }
  .skill-name {
    font-size: 2rem;
    margin-bottom: 10px;
    color: #7d7d7d;
  }
  .progress-bar {
    width: 100%;
    height: 20px;
    background: #eee;
    border-radius: 15px;
    position: relative;
  }
  .progress {
    height: 100%;
    border-radius: 15px;
    background: #00bfa6;
    transition: width 1s ease-in-out;
  }
  .design .progress {
    width: 90%;
  }

  .digital-marketing .progress {
    width: 80%;
  }

  .frontend .progress {
    width: 85%;
  }
  .backend .progress {
    width: 55%;
  }
  .programming .progress {
    width: 50%;
  }

  @media (max-width: 768px) {
    .container {
      grid-template-columns: 1fr;
      padding: 2rem;
      height: auto;
    }
    h3 {
      font-size: 4rem;
      padding: 1rem 0;
      text-align: center;
    }
    .skill-name {
      font-size: 1.5rem;
    }
  }
</style>
