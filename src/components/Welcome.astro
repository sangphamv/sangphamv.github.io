<style>


  .container {
    margin: 0 auto;
    max-width: 120rem;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    align-items: center;
    height: 100vh;
  }

  .content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 4rem;
  }

  .content h1 {
    font-family: "Montserrat", sans-serif;
    font-size: 8rem;
    font-weight: 600;
    color: #000000;
  }

  .content h3 {
    font-family: "Montserrat", sans-serif;
    font-size: 5rem;
    font-weight: 400;
    color: #333;
  }

  .content p {
    font-size: 2rem;
    color: #333;
  }

  .social-icons {
    display: flex;
    gap: 15px;
  }

  .group-btn {
    display: flex;
    gap: 2rem;
  }

  .btn {
    background-color: #00bfa6;
    padding: 14px 40px;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 2px;
    cursor: pointer;
    border-radius: 10px;
    border: 2px dashed #00bfa6;
    box-shadow:
      rgba(50, 50, 93, 0.25) 0px 2px 5px -1px,
      rgba(0, 0, 0, 0.3) 0px 1px 3px -1px;
    transition: 0.4s;
  }

  .btn span:last-child {
    display: none;
  }

  .btn:hover {
    transition: 0.4s;
    border: 2px dashed #00bfa6;
    background-color: #fff;
    color: #00bfa6;
  }

  .btn:active {
    background-color: #87dbd0;
  }

  .social-icons a {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 5rem;
    height: 5rem;
    border-radius: 50%;
    color: white;
    text-decoration: none;
    transition: 0.3s ease;
  }

  .social-icons a svg {
    width: 3rem;
    height: 3rem;
    fill: white;
  }

  .github {
    background-color: #333;
  }
  .linkedin {
    background-color: #0077b5;
  }
  .email {
    background-color: #e74c3c;
  }
  .gitlab {
    background-color: #fc6d26;
  }
  .behance {
    background-color: #1877f2;
  }
  .dribble {
    background-color: #ea4c89;
  }
  .stackoverflow {
    background-color: #f48024;
  }

  .zalo {
    background-color: #2563eb;
  }

  .social-icons a:hover {
    opacity: 0.7;
  }

  .hero {
    display: flex;
    justify-content: center;
  }

  .hero img {
    width: 50rem;
    height: auto;

    -webkit-mask-image: radial-gradient(
      circle,
      rgba(0, 0, 0, 1) 30%,
      rgba(0, 0, 0, 0) 100%
    );
    mask-image: radial-gradient(
      circle,
      rgba(0, 0, 0, 1) 30%,
      rgba(0, 0, 0, 0) 100%
    );
  }


  @media (max-width: 768px) {
    .container {
      text-align: center;
      grid-template-columns: 1fr; /* Chuyển sang một cột */
      padding: 2rem;
      width: 100%;
      height: auto;
    }

    .content {
      gap: 2rem;
    }

    .content h1 {
      font-size: 6rem; /* Giảm kích thước h1 */
    }

    .content h3 {
      font-size: 2.5rem; /* Giảm kích thước h3 */
    }

    .content p {
      font-size: 1.6rem; /* Điều chỉnh kích thước chữ */
    }

    .hero img {
      width: 100%; /* Đảm bảo hình ảnh co giãn theo màn hình */
      height: auto;
    }

    .group-btn{
      flex-direction: column; /* Đặt các nút xuống hàng */
      gap: 1rem; /* Giảm khoảng cách giữa các nút */
    }

    .social-icons {
      flex-wrap: wrap; /* Cho phép các biểu tượng xã hội xuống hàng */
      justify-content: center; /* Căn giữa các biểu tượng xã hội */
    }
  }
</style>
